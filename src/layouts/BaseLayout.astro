---
import "../styles/global.css";
import Taskbar from "../components/Taskbar.astro";
import StartMenu from "../components/StartMenu.astro";

interface Props {
  title?: string;
}

const { title = "Alexandre's Computer" } = Astro.props;
---

<!doctype html>
<html lang="en" data-default-lang>
  <head>
    <script is:inline>
      (function() {
        var l = localStorage.getItem('xp-locale');
        if (l === 'fr') {
          document.documentElement.lang = 'fr';
        } else if (l === 'en') {
          document.documentElement.lang = 'en';
        } else if (navigator.language && navigator.language.slice(0, 2).toLowerCase() === 'fr') {
          document.documentElement.lang = 'fr';
        }
        document.documentElement.removeAttribute('data-default-lang');
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Alexandre's portfolio — Windows XP edition"
    />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <div id="desktop-shell">
      <div id="desktop-area">
        <slot />
      </div>
      <div id="taskbar-wrapper">
        <StartMenu />
        <Taskbar />
      </div>
    </div>
  </body>
</html>
